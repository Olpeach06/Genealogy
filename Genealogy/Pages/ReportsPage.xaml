<Page x:Class="Genealogy.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Отчеты"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Тень для панелей -->
        <DropShadowEffect x:Key="ShadowEffect" 
                          BlurRadius="10" 
                          Opacity="0.1" 
                          ShadowDepth="2" 
                          Color="#5C4E3D"/>

        <!-- Конвертер для видимости -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхнее меню -->
        <Border Grid.Row="0" 
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource ShadowEffect}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,40,0">
                    <Border Width="35" Height="35" CornerRadius="8" Background="#8FAA7A" Margin="0,0,8,0">
                        <TextBlock Text="🌳" FontSize="20" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Genealogy" FontSize="20" FontWeight="SemiBold" 
                               Foreground="#5C4E3D" Margin="5,0,0,0" Height="28"/>
                </StackPanel>

                <!-- Навигация -->
                <Button Grid.Column="1" Content="Главная" Click="MainPageButton_Click" Margin="5,0"
                        Background="Transparent"
                        Foreground="#6B5E4A"
                        BorderThickness="0"
                        Padding="15,8"
                        FontSize="14"
                        FontWeight="Medium"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" 
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" Content="Мои деревья" Click="TreesButton_Click" Margin="5,0"
                        Background="Transparent"
                        Foreground="#6B5E4A"
                        BorderThickness="0"
                        Padding="15,8"
                        FontSize="14"
                        FontWeight="Medium"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" 
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3" Content="Отчеты" IsEnabled="False" Margin="5,0"
                        Background="Transparent"
                        Foreground="#8FAA7A"
                        BorderThickness="0"
                        Padding="15,8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" 
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Кнопка Пользователи (видна только админам и редакторам) -->
                <Button Grid.Column="4" 
                        x:Name="btnUsers"
                        Content="👥 Пользователи" 
                        Click="UsersButton_Click" 
                        Margin="5,0"
                        Background="Transparent"
                        Foreground="#6B5E4A"
                        BorderThickness="0"
                        Padding="15,8"
                        FontSize="14"
                        FontWeight="Medium"
                        Cursor="Hand"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" 
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                <Setter Property="Foreground" Value="#8FAA7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Профиль -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#F5F0E6" CornerRadius="20" Padding="10,5,15,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="14" Foreground="#8FAA7A" Margin="0,0,8,0" Height="20"/>
                            <TextBlock x:Name="txtUserName"
                                       Text="Имя пользователя"
                                       VerticalAlignment="Center"
                                       Foreground="#5C4E3D"
                                       FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Выйти" 
                            Click="LogoutButton_Click"
                            Background="Transparent"
                            BorderBrush="#D6C9B8"
                            BorderThickness="1"
                            Foreground="#8B7E6B"
                            Padding="12,5"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" 
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F0E9DE"/>
                                                    <Setter Property="Foreground" Value="#8FAA7A"/>
                                                    <Setter Property="BorderBrush" Value="#8FAA7A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">

                <!-- Заголовок и панель управления -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="ОТЧЕТЫ И СТАТИСТИКА" 
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#5C4E3D"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- Кнопки экспорта (только для админа/редактора) -->
                        <StackPanel x:Name="panelExport" 
                                    Orientation="Horizontal" 
                                    Visibility="Collapsed">
                            <Button Content="📄 PDF" 
                                    Width="90" Height="32"
                                    Background="#8FAA7A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Margin="0,0,5,0"
                                    Click="ExportPdf_Click"
                                    FontSize="12"/>
                            <Button Content="📊 EXCEL" 
                                    Width="90" Height="32"
                                    Background="#8FAA7A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Margin="5,0,5,0"
                                    Click="ExportExcel_Click"
                                    FontSize="12"/>
                            <Button Content="🖨️ ПЕЧАТЬ" 
                                    Width="90" Height="32"
                                    Background="Transparent"
                                    BorderBrush="#D6C9B8"
                                    Foreground="#6B5E4A"
                                    BorderThickness="1"
                                    Margin="5,0,10,0"
                                    Click="PrintButton_Click"
                                    FontSize="12"/>
                        </StackPanel>

                        <TextBlock Text="Дерево:" Foreground="#6B5E4A" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <ComboBox x:Name="cmbTrees" 
                                  Width="200" Height="35"
                                  Background="White"
                                  BorderBrush="#D6C9B8"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectionChanged="TreeSelectionChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Блок 1: Общая статистика (карточки) -->
                <Border Background="#FDF8F0"
                        CornerRadius="10"
                        BorderBrush="#D6C9B8"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="ОБЩАЯ СТАТИСТИКА" 
                                   Foreground="#5C4E3D"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Карточка 1: Всего персон -->
                            <Border Grid.Column="0" 
                                    Background="#F5F0E6"
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="0,0,5,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="👥" FontSize="32" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtTotalPersons" 
                                               Text="0" 
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="#5C4E3D"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Всего персон" 
                                               Foreground="#8B7E6B"
                                               FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Карточка 2: Семей -->
                            <Border Grid.Column="1" 
                                    Background="#F5F0E6"
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="5,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="👪" FontSize="32" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtTotalFamilies" 
                                               Text="0" 
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="#5C4E3D"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Семей" 
                                               Foreground="#8B7E6B"
                                               FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Карточка 3: Браков -->
                            <Border Grid.Column="2" 
                                    Background="#F5F0E6"
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="5,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="💍" FontSize="32" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtTotalMarriages" 
                                               Text="0" 
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="#5C4E3D"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Браков" 
                                               Foreground="#8B7E6B"
                                               FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Карточка 4: Умерших -->
                            <Border Grid.Column="3" 
                                    Background="#F5F0E6"
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="5,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="⚰️" FontSize="32" Foreground="#8FAA7A" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtTotalDeceased" 
                                               Text="0" 
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="#5C4E3D"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Умерших" 
                                               Foreground="#8B7E6B"
                                               FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Блок 2: Демография -->
                <Border Background="#FDF8F0"
                        CornerRadius="10"
                        BorderBrush="#D6C9B8"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="ДЕМОГРАФИЯ" 
                                   Foreground="#5C4E3D"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая колонка: Пол -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Распределение по полу" 
                                           Foreground="#6B5E4A"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="♂ Мужчины:" 
                                               Foreground="#5C4E3D"
                                               Margin="0,0,5,5"/>
                                    <ProgressBar Grid.Row="0" Grid.Column="1" 
                                                 x:Name="progressMen"
                                                 Height="20"
                                                 Minimum="0" Maximum="100"
                                                 Foreground="#5C4E3D"
                                                 Background="#F5F0E6"
                                                 BorderBrush="#D6C9B8"
                                                 Margin="0,0,5,5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" 
                                               x:Name="txtMenPercent"
                                               Text="0%" 
                                               Foreground="#6B5E4A"
                                               Margin="0,0,0,5"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="♀ Женщины:" 
                                               Foreground="#5C4E3D"
                                               Margin="0,0,5,5"/>
                                    <ProgressBar Grid.Row="1" Grid.Column="1" 
                                                 x:Name="progressWomen"
                                                 Height="20"
                                                 Minimum="0" Maximum="100"
                                                 Foreground="#8FAA7A"
                                                 Background="#F5F0E6"
                                                 BorderBrush="#D6C9B8"
                                                 Margin="0,0,5,5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" 
                                               x:Name="txtWomenPercent"
                                               Text="0%" 
                                               Foreground="#6B5E4A"
                                               Margin="0,0,0,5"/>
                                </Grid>
                            </StackPanel>

                            <!-- Правая колонка: Возраст -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Возрастная статистика" 
                                           Foreground="#6B5E4A"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="Средний возраст:" 
                                               Foreground="#6B5E4A"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               x:Name="txtAverageAge"
                                               Text="0 лет" 
                                               Foreground="#5C4E3D"
                                               FontWeight="Bold"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Самый старший:" 
                                               Foreground="#6B5E4A"
                                               Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               x:Name="txtOldestPerson"
                                               Text="—" 
                                               Foreground="#5C4E3D"
                                               FontWeight="Bold"
                                               Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" 
                                               Text="Самый младший:" 
                                               Foreground="#6B5E4A"
                                               Margin="0,5,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" 
                                               x:Name="txtYoungestPerson"
                                               Text="—" 
                                               Foreground="#5C4E3D"
                                               FontWeight="Bold"
                                               Margin="0,5,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Блок 3: Поколения и Ближайшие события (в одной строке) -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка: Поколения -->
                    <Border Grid.Column="0" 
                            Background="#FDF8F0"
                            CornerRadius="10"
                            BorderBrush="#D6C9B8"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="РАСПРЕДЕЛЕНИЕ ПО ПОКОЛЕНИЯМ" 
                                       Foreground="#5C4E3D"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <TextBlock x:Name="txtTotalGenerations" 
                                       Text="Всего поколений: 0" 
                                       Foreground="#6B5E4A"
                                       Margin="0,0,0,10"/>

                            <ListView x:Name="lvGenerations" 
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      MaxHeight="300">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Name}" 
                                                       Foreground="#5C4E3D"/>

                                            <ProgressBar Grid.Column="1" 
                                                         Height="20"
                                                         Minimum="0" Maximum="{Binding MaxCount}"
                                                         Value="{Binding Count}"
                                                         Foreground="#8FAA7A"
                                                         Background="#F5F0E6"
                                                         BorderBrush="#D6C9B8"
                                                         Margin="5,0"/>

                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding CountText}" 
                                                       Foreground="#6B5E4A"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Правая колонка: Ближайшие события -->
                    <Border Grid.Column="2" 
                            Background="#FDF8F0"
                            CornerRadius="10"
                            BorderBrush="#D6C9B8"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="БЛИЖАЙШИЕ СОБЫТИЯ" 
                                           Foreground="#5C4E3D"
                                           FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1" 
                                        x:Name="btnCalendar"
                                        Content="📅 КАЛЕНДАРЬ" 
                                        Width="110" Height="32"
                                        Background="#8FAA7A"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Click="CalendarButton_Click"/>
                            </Grid>

                            <ListView x:Name="lvEvents" 
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      MaxHeight="300"
                                      Margin="0,10,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F5F0E6"
                                                CornerRadius="5"
                                                Padding="10"
                                                Margin="0,0,0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Date}" 
                                                           Foreground="#8FAA7A"
                                                           FontWeight="Bold"/>

                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Description}" 
                                                           Foreground="#6B5E4A"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock x:Name="txtNoEvents" 
                                       Text="Нет ближайших событий" 
                                       Foreground="#B7A48B"
                                       HorizontalAlignment="Center"
                                       Margin="10"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Блок 4: Популярные имена и Медиафайлы (в одной строке) -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка: Популярные имена -->
                    <Border Grid.Column="0" 
                            Background="#FDF8F0"
                            CornerRadius="10"
                            BorderBrush="#D6C9B8"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="ПОПУЛЯРНЫЕ ИМЕНА" 
                                       Foreground="#5C4E3D"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Мужские имена -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Мужские" 
                                               Foreground="#5C4E3D"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10"/>
                                    <ListView x:Name="lvMaleNames" 
                                              BorderThickness="0"
                                              Background="Transparent"
                                              MaxHeight="150"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding Name}" 
                                                               Foreground="#6B5E4A"/>
                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding Count}" 
                                                               Foreground="#8FAA7A"
                                                               FontWeight="Bold"
                                                               Margin="5,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>

                                <!-- Женские имена -->
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Женские" 
                                               Foreground="#5C4E3D"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10"/>
                                    <ListView x:Name="lvFemaleNames" 
                                              BorderThickness="0"
                                              Background="Transparent"
                                              MaxHeight="150"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding Name}" 
                                                               Foreground="#6B5E4A"/>
                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding Count}" 
                                                               Foreground="#8FAA7A"
                                                               FontWeight="Bold"
                                                               Margin="5,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Grid>

                            <!-- Популярные фамилии -->
                            <TextBlock Text="Популярные фамилии" 
                                       Foreground="#5C4E3D"
                                       FontWeight="SemiBold"
                                       Margin="0,15,0,5"/>
                            <ListView x:Name="lvSurnames" 
                                      BorderThickness="0"
                                      Background="Transparent"
                                      MaxHeight="150"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Name}" 
                                                       Foreground="#6B5E4A"/>
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Count}" 
                                                       Foreground="#8FAA7A"
                                                       FontWeight="Bold"
                                                       Margin="5,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Правая колонка: Медиафайлы -->
                    <Border Grid.Column="2" 
                            Background="#FDF8F0"
                            CornerRadius="10"
                            BorderBrush="#D6C9B8"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="МЕДИАФАЙЛЫ" 
                                       Foreground="#5C4E3D"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Всего файлов:" Foreground="#6B5E4A"/>
                                    <TextBlock x:Name="txtTotalMedia" 
                                               Text="0" 
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="#5C4E3D"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="📷 Фото:" 
                                                   Foreground="#6B5E4A"
                                                   Width="50"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="txtPhotoCount"
                                                   Text="0" 
                                                   Foreground="#5C4E3D"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="🎥 Видео:" 
                                                   Foreground="#6B5E4A"
                                                   Width="50"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="txtVideoCount"
                                                   Text="0" 
                                                   Foreground="#5C4E3D"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="🎵 Аудио:" 
                                                   Foreground="#6B5E4A"
                                                   Width="50"/>
                                        <TextBlock Grid.Column="1" 
                                                   x:Name="txtAudioCount"
                                                   Text="0" 
                                                   Foreground="#5C4E3D"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="txtTopMediaPerson" 
                                       Text="Больше всего медиа у: —" 
                                       Foreground="#8B7E6B"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>