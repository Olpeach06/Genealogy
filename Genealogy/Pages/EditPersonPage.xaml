<Page x:Class="Genealogy.Pages.EditPersonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="Редактирование персоны"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <!-- Декоративный элемент -->
        <Border Width="500" Height="500" 
                Background="#8B7E6B" Opacity="0.05"
                CornerRadius="250"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

        <!-- Карточка редактирования -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="650">
            <Border Width="550" 
                    Background="#FDF8F0"
                    CornerRadius="20"
                    Padding="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#B7A48B"
                    BorderThickness="1"
                    Margin="20">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" 
                                      Opacity="0.15" 
                                      ShadowDepth="5" 
                                      Color="#5C4E3D"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Заголовок -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Grid Width="60" Height="60" Margin="0,0,0,5">
                            <Rectangle Width="15" Height="30" 
                                       Fill="#B7A48B" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"
                                       RadiusX="3" RadiusY="3"/>
                            <Ellipse Width="45" Height="45" 
                                     Fill="#9CAF88" 
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"
                                     Margin="0,0,0,20"/>
                        </Grid>

                        <TextBlock x:Name="txtTitle" 
                                   Text="ДОБАВЛЕНИЕ ПЕРСОНЫ" 
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="#5C4E3D"
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="Заполните информацию"
                                   Foreground="#8B7E6B"
                                   FontSize="13"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Основная информация -->
                    <GroupBox Header="Основная информация" 
                              BorderBrush="#B7A48B" 
                              Foreground="#5C4E3D"
                              Margin="0,0,0,15">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Фамилия -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Фамилия *" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                     x:Name="txtLastName"
                                     Padding="8" 
                                     BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1"
                                     Background="Transparent"
                                     Margin="0,0,0,10"/>

                            <!-- Имя -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Имя *" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <TextBox Grid.Row="1" Grid.Column="1" 
                                     x:Name="txtFirstName"
                                     Padding="8" 
                                     BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1"
                                     Background="Transparent"
                                     Margin="0,0,0,10"/>

                            <!-- Отчество -->
                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                       Text="Отчество" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <TextBox Grid.Row="2" Grid.Column="1" 
                                     x:Name="txtPatronymic"
                                     Padding="8" 
                                     BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1"
                                     Background="Transparent"
                                     Margin="0,0,0,10"/>

                            <!-- Девичья фамилия -->
                            <TextBlock Grid.Row="3" Grid.Column="0" 
                                       Text="Девичья фамилия" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <TextBox Grid.Row="3" Grid.Column="1" 
                                     x:Name="txtMaidenName"
                                     Padding="8" 
                                     BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1"
                                     Background="Transparent"
                                     Margin="0,0,0,10"/>

                            <!-- Пол -->
                            <TextBlock Grid.Row="4" Grid.Column="0" 
                                       Text="Пол *" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" 
                                      x:Name="cmbGender"
                                      Height="35"
                                      BorderBrush="#B7A48B"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Мужской"/>
                                <ComboBoxItem Content="Женский"/>
                                <ComboBoxItem Content="Не указан"/>
                            </ComboBox>
                        </Grid>
                    </GroupBox>

                    <!-- Даты жизни -->
                    <GroupBox Header="Даты жизни" 
                              BorderBrush="#B7A48B" 
                              Foreground="#5C4E3D"
                              Margin="0,0,0,15">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Дата рождения -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Дата рождения" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <DatePicker Grid.Row="0" Grid.Column="1" 
                                        x:Name="dpBirthDate"
                                        Height="35"
                                        BorderBrush="#B7A48B"
                                        SelectedDateFormat="Short"
                                        Margin="0,0,0,10"/>

                            <!-- Дата смерти -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Дата смерти" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <DatePicker Grid.Row="1" Grid.Column="1" 
                                        x:Name="dpDeathDate"
                                        Height="35"
                                        BorderBrush="#B7A48B"
                                        SelectedDateFormat="Short"/>
                        </Grid>
                    </GroupBox>

                    <!-- Места -->
                    <GroupBox Header="Места" 
                              BorderBrush="#B7A48B" 
                              Foreground="#5C4E3D"
                              Margin="0,0,0,15">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Место рождения -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Место рождения" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                     x:Name="txtBirthPlace"
                                     Padding="8" 
                                     BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1"
                                     Background="Transparent"
                                     Margin="0,0,0,10"/>

                            <!-- Место смерти -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Место смерти" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <TextBox Grid.Row="1" Grid.Column="1" 
                                     x:Name="txtDeathPlace"
                                     Padding="8" 
                                     BorderBrush="#B7A48B" 
                                     BorderThickness="0,0,0,1"
                                     Background="Transparent"/>
                        </Grid>
                    </GroupBox>

                    <!-- Родственные связи -->
                    <GroupBox Header="Родственные связи" 
                              BorderBrush="#B7A48B" 
                              Foreground="#5C4E3D"
                              Margin="0,0,0,15">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Отец -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Отец" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                      x:Name="cmbFather"
                                      Height="35"
                                      BorderBrush="#B7A48B"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      Margin="0,0,5,10"/>
                            <Button Grid.Row="0" Grid.Column="2" 
                                    Content="🔍" Width="35" Height="35"
                                    Background="Transparent"
                                    BorderBrush="#B7A48B"
                                    BorderThickness="1"
                                    Click="FindFather_Click"
                                    Margin="0,0,0,10"/>

                            <!-- Мать -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Мать" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" 
                                      x:Name="cmbMother"
                                      Height="35"
                                      BorderBrush="#B7A48B"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      Margin="0,0,5,10"/>
                            <Button Grid.Row="1" Grid.Column="2" 
                                    Content="🔍" Width="35" Height="35"
                                    Background="Transparent"
                                    BorderBrush="#B7A48B"
                                    BorderThickness="1"
                                    Click="FindMother_Click"
                                    Margin="0,0,0,10"/>

                            <!-- Супруг(а) -->
                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                       Text="Супруг(а)" 
                                       Foreground="#6B5E4A" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" 
                                      x:Name="cmbSpouse"
                                      Height="35"
                                      BorderBrush="#B7A48B"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      Margin="0,0,5,0"/>
                            <Button Grid.Row="2" Grid.Column="2" 
                                    Content="🔍" Width="35" Height="35"
                                    Background="Transparent"
                                    BorderBrush="#B7A48B"
                                    BorderThickness="1"
                                    Click="FindSpouse_Click"/>
                        </Grid>
                    </GroupBox>

                    <!-- Биография -->
                    <GroupBox Header="Биография" 
                              BorderBrush="#B7A48B" 
                              Foreground="#5C4E3D"
                              Margin="0,0,0,15">
                        <TextBox x:Name="txtBiography"
                                 Height="100"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Padding="8"
                                 BorderBrush="#B7A48B"
                                 Background="Transparent"
                                 Margin="10"/>
                    </GroupBox>

                    <!-- Фото -->
                    <GroupBox Header="Фотография" 
                              BorderBrush="#B7A48B" 
                              Foreground="#5C4E3D"
                              Margin="0,0,0,20">
                        <StackPanel Margin="10" Orientation="Horizontal">
                            <Border Width="80" Height="80"
                                    BorderBrush="#B7A48B"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Background="#F5F0E6"
                                    Margin="0,0,10,0">
                                <Grid>
                                    <Image x:Name="imgPreview" 
                                           Stretch="UniformToFill"
                                           Visibility="Collapsed"/>
                                    <TextBlock x:Name="txtNoImage" 
                                               Text="📷" 
                                               FontSize="30"
                                               Foreground="#B7A48B"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Visible"/>
                                </Grid>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <Button Content="Выбрать фото" 
                                        Width="120" Height="30"
                                        Background="#8FAA7A"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Margin="0,0,0,5"
                                        Click="SelectPhoto_Click"/>
                                <Button x:Name="btnRemovePhoto" 
                                        Content="Удалить" 
                                        Width="120" Height="30"
                                        Background="Transparent"
                                        BorderBrush="#D6C9B8"
                                        Foreground="#6B5E4A"
                                        BorderThickness="1"
                                        Click="RemovePhoto_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Кнопки -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" 
                                Content="ОТМЕНА" 
                                Width="120" Height="40"
                                Background="Transparent"
                                BorderBrush="#D6C9B8"
                                Foreground="#6B5E4A"
                                BorderThickness="1"
                                Margin="0,0,10,0"
                                HorizontalAlignment="Right"
                                Click="CancelButton_Click"/>

                        <Button Grid.Column="1" 
                                x:Name="btnSave"
                                Content="СОХРАНИТЬ" 
                                Width="120" Height="40"
                                Background="#8FAA7A"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                Click="SaveButton_Click"/>
                    </Grid>

                    <TextBlock x:Name="txtRequiredInfo" 
                               Text="* - обязательные поля"
                               Foreground="#B7A48B"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>