<Page x:Class="Genealogy.Pages.TreesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Мои деревья"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== ВЕРХНЕЕ МЕНЮ ==================== -->
        <Border Grid.Row="0" 
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="🌳" FontSize="24" Foreground="#8FAA7A"/>
                    <TextBlock Text="Genealogy" FontSize="18" FontWeight="SemiBold" 
                               Foreground="#5C4E3D" Margin="5,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Главная" Click="MainPageButton_Click" Margin="5,0"/>
                <Button Grid.Column="2" Content="Мои деревья" IsEnabled="False" Margin="5,0"/>
                <Button Grid.Column="3" Content="Отчеты" Click="ReportsButton_Click" Margin="5,0"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="txtUserName"
                               Text="Имя пользователя"
                               VerticalAlignment="Center"
                               Foreground="#5C4E3D"
                               FontWeight="Medium"
                               Margin="0,0,15,0"/>
                    <Button Content="Выйти" 
                            Click="LogoutButton_Click"
                            Background="Transparent"
                            BorderBrush="#D6C9B8"
                            BorderThickness="1"
                            Foreground="#8B7E6B"
                            Padding="10,5"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Заголовок и кнопка создания -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="МОИ ГЕНЕАЛОГИЧЕСКИЕ ДЕРЕВЬЯ" 
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#5C4E3D"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" 
                            x:Name="btnCreateTree"
                            Content="➕ СОЗДАТЬ" 
                            Width="120" Height="40"
                            Background="#8FAA7A"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CreateTreeButton_Click"/>
                </Grid>

                <!-- Текущее дерево (если есть) -->
                <Border x:Name="borderCurrentTree" 
                        Background="#FDF8F0"
                        CornerRadius="10"
                        BorderBrush="#8FAA7A"
                        BorderThickness="2"
                        Padding="20"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="● ТЕКУЩЕЕ ДЕРЕВО" 
                                   Foreground="#8FAA7A"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Border x:Name="currentTreeCard"
                                Background="#F5F0E6"
                                CornerRadius="8"
                                Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="🌳" 
                                           FontSize="32"
                                           Foreground="#8FAA7A"
                                           Margin="0,0,15,0"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="txtCurrentTreeName" 
                                               Text="Семья Ивановых" 
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#5C4E3D"/>
                                    <TextBlock x:Name="txtCurrentTreeDesc" 
                                               Text="Основное семейное древо"
                                               Foreground="#8B7E6B"
                                               Margin="0,2,0,5"/>
                                    <WrapPanel>
                                        <TextBlock x:Name="txtCurrentTreeStats" 
                                                   Text="👥 12 персон  |  📖 5 историй  |  📷 23 фото"
                                                   Foreground="#6B5E4A"
                                                   FontSize="12"/>
                                    </WrapPanel>
                                    <TextBlock x:Name="txtCurrentTreeDate" 
                                               Text="Создано: 15.03.2025"
                                               Foreground="#B7A48B"
                                               FontSize="11"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" 
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="ВЫБРАНО" 
                                            Width="80" Height="30"
                                            Background="#8FAA7A"
                                            Foreground="White"
                                            BorderThickness="0"
                                            IsEnabled="False"
                                            Margin="0,0,5,0"/>
                                    <Button x:Name="btnEditCurrent" 
                                            Content="✎" 
                                            Width="30" Height="30"
                                            Background="Transparent"
                                            BorderBrush="#D6C9B8"
                                            Foreground="#6B5E4A"
                                            BorderThickness="1"
                                            Margin="0,0,5,0"
                                            Click="EditTreeButton_Click"/>
                                    <Button x:Name="btnDeleteCurrent" 
                                            Content="🗑" 
                                            Width="30" Height="30"
                                            Background="Transparent"
                                            BorderBrush="#D6C9B8"
                                            Foreground="#6B5E4A"
                                            BorderThickness="1"
                                            Click="DeleteTreeButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Другие деревья -->
                <Border Background="#FDF8F0"
                        CornerRadius="10"
                        BorderBrush="#D6C9B8"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="● ДРУГИЕ ДЕРЕВЬЯ" 
                                   Foreground="#8B7E6B"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <!-- Список деревьев -->
                        <ListView x:Name="lvTrees" 
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F0E6"
                                            CornerRadius="8"
                                            Padding="15"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       Text="🌳" 
                                                       FontSize="32"
                                                       Foreground="#8FAA7A"
                                                       Margin="0,0,15,0"
                                                       VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="16" FontWeight="Bold"
                                                           Foreground="#5C4E3D"/>
                                                <TextBlock Text="{Binding Description}" 
                                                           Foreground="#8B7E6B"
                                                           Margin="0,2,0,5"
                                                           TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <TextBlock Text="{Binding Stats}" 
                                                               Foreground="#6B5E4A"
                                                               FontSize="12"/>
                                                </WrapPanel>
                                                <TextBlock Text="{Binding CreatedDate}" 
                                                           Foreground="#B7A48B"
                                                           FontSize="11"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" 
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="ВЫБРАТЬ" 
                                                        Width="80" Height="30"
                                                        Background="#8FAA7A"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Margin="0,0,5,0"
                                                        Tag="{Binding Id}"
                                                        Click="SelectTreeButton_Click"/>
                                                <Button Content="✎" 
                                                        Width="30" Height="30"
                                                        Background="Transparent"
                                                        BorderBrush="#D6C9B8"
                                                        Foreground="#6B5E4A"
                                                        BorderThickness="1"
                                                        Margin="0,0,5,0"
                                                        Tag="{Binding Id}"
                                                        Click="EditTreeButton_Click"/>
                                                <Button Content="🗑" 
                                                        Width="30" Height="30"
                                                        Background="Transparent"
                                                        BorderBrush="#D6C9B8"
                                                        Foreground="#6B5E4A"
                                                        BorderThickness="1"
                                                        Tag="{Binding Id}"
                                                        Click="DeleteTreeButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Сообщение, если нет других деревьев -->
                        <TextBlock x:Name="txtNoTrees" 
                                   Text="У вас пока нет других деревьев. Создайте новое!"
                                   Foreground="#B7A48B"
                                   HorizontalAlignment="Center"
                                   Margin="20"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>