<Page x:Class="Genealogy.Pages.PersonProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Профиль персоны"
      Background="#F5F0E6"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопкой назад -->
        <Border Grid.Row="0" 
                Background="#FDF8F0"
                BorderBrush="#D6C9B8"
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Назад к дереву" 
                        Click="BackButton_Click"
                        Background="Transparent"
                        BorderBrush="#B7A48B"
                        Foreground="#5C4E3D"
                        Padding="15,8"
                        BorderThickness="1"
                        Cursor="Hand"/>
                <TextBlock x:Name="txtPageTitle" 
                           Text="Профиль персоны"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#5C4E3D"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Карточка профиля -->
                <Border Background="#FDF8F0"
                        CornerRadius="15"
                        Padding="25"
                        BorderBrush="#B7A48B"
                        BorderThickness="1"
                        Margin="0,0,0,20">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Фото -->
                        <Border Grid.Column="0" 
                                Width="160" Height="160"
                                BorderBrush="#B7A48B"
                                BorderThickness="1"
                                CornerRadius="10"
                                Background="#F5F0E6"
                                HorizontalAlignment="Left">
                            <Grid>
                                <Image x:Name="imgProfile" 
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                                <TextBlock x:Name="txtNoProfilePhoto" 
                                           Text="📷" 
                                           FontSize="60"
                                           Foreground="#B7A48B"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Visible"/>
                            </Grid>
                        </Border>

                        <!-- Основная информация -->
                        <StackPanel Grid.Column="1" Margin="20,0">
                            <TextBlock x:Name="txtFullName" 
                                       Text="Иванов Иван Иванович"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#5C4E3D"/>

                            <WrapPanel Margin="0,5,0,10">
                                <TextBlock Text="📅 " Foreground="#8FAA7A" FontSize="16"/>
                                <TextBlock x:Name="txtBirthDate" 
                                           Text="15.03.1985" 
                                           Foreground="#6B5E4A" 
                                           FontSize="16"/>
                                <TextBlock Text=" — " Foreground="#6B5E4A" FontSize="16"/>
                                <TextBlock x:Name="txtDeathDate" 
                                           Text="..." 
                                           Foreground="#6B5E4A" 
                                           FontSize="16"/>
                            </WrapPanel>

                            <WrapPanel Margin="0,0,0,10">
                                <TextBlock x:Name="txtGenderSymbol" 
                                           Text="♂" 
                                           Foreground="#8FAA7A" 
                                           FontSize="16"
                                           Margin="0,0,5,0"/>
                                <TextBlock x:Name="txtGender" 
                                           Text="Мужской" 
                                           Foreground="#6B5E4A" 
                                           FontSize="16"/>
                            </WrapPanel>

                            <WrapPanel Margin="0,0,0,10">
                                <TextBlock Text="📍 " Foreground="#8FAA7A" FontSize="16"/>
                                <TextBlock x:Name="txtBirthPlace" 
                                           Text="Место рождения: Москва" 
                                           Foreground="#6B5E4A" 
                                           FontSize="14"/>
                            </WrapPanel>

                            <WrapPanel>
                                <TextBlock Text="⚰️ " Foreground="#8FAA7A" FontSize="16"/>
                                <TextBlock x:Name="txtDeathPlace" 
                                           Text="Место смерти: —" 
                                           Foreground="#6B5E4A" 
                                           FontSize="14"/>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Кнопки действий -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <Button x:Name="btnEdit" 
                                    Content="✎ Редактировать" 
                                    Width="140" Height="35"
                                    Background="#8FAA7A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Margin="0,0,0,10"
                                    Click="EditButton_Click"/>
                            <Button x:Name="btnAddStory" 
                                    Content="📖 Добавить историю" 
                                    Width="140" Height="35"
                                    Background="Transparent"
                                    BorderBrush="#B7A48B"
                                    Foreground="#5C4E3D"
                                    BorderThickness="1"
                                    Margin="0,0,0,10"
                                    Click="AddStoryButton_Click"/>
                            <Button x:Name="btnAddPhoto" 
                                    Content="📷 Добавить фото" 
                                    Width="140" Height="35"
                                    Background="Transparent"
                                    BorderBrush="#B7A48B"
                                    Foreground="#5C4E3D"
                                    BorderThickness="1"
                                    Click="AddPhotoButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Родственные связи -->
                <Border Background="#FDF8F0"
                        CornerRadius="15"
                        Padding="20"
                        BorderBrush="#B7A48B"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="👨‍👩‍👧 Родственные связи" 
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#5C4E3D"
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Родители -->
                            <Border Grid.Column="0" 
                                    Background="#F5F0E6"
                                    CornerRadius="10"
                                    Padding="15"
                                    Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Родители" 
                                               FontWeight="Bold"
                                               Foreground="#5C4E3D"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="txtFather" 
                                               Text="Отец: Петр Иванов" 
                                               Foreground="#6B5E4A"
                                               Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtMother" 
                                               Text="Мать: Анна Иванова" 
                                               Foreground="#6B5E4A"/>
                                </StackPanel>
                            </Border>

                            <!-- Супруг(а) -->
                            <Border Grid.Column="1" 
                                    Background="#F5F0E6"
                                    CornerRadius="10"
                                    Padding="15"
                                    Margin="5,0">
                                <StackPanel>
                                    <TextBlock Text="Супруг(а)" 
                                               FontWeight="Bold"
                                               Foreground="#5C4E3D"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="txtSpouse" 
                                               Text="Елена Иванова" 
                                               Foreground="#6B5E4A"/>
                                </StackPanel>
                            </Border>

                            <!-- Дети -->
                            <Border Grid.Column="2" 
                                    Background="#F5F0E6"
                                    CornerRadius="10"
                                    Padding="15"
                                    Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Дети" 
                                               FontWeight="Bold"
                                               Foreground="#5C4E3D"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="txtChildren" 
                                               Text="Анна, Павел" 
                                               Foreground="#6B5E4A"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Биография с ScrollViewer -->
                <Border Background="#FDF8F0"
                        CornerRadius="15"
                        Padding="20"
                        BorderBrush="#B7A48B"
                        BorderThickness="1"
                        Margin="0,0,0,20"
                        Height="150">
                    <StackPanel>
                        <TextBlock Text="📖 Биография" 
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#5C4E3D"
                                   Margin="0,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="100">
                            <TextBlock x:Name="txtBiography" 
                                       Text="Родился в Москве. Окончил школу №123. Работает программистом."
                                       TextWrapping="Wrap"
                                       Foreground="#6B5E4A"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Истории и воспоминания с ScrollViewer -->
                <Border Background="#FDF8F0"
                        CornerRadius="15"
                        Padding="20"
                        BorderBrush="#B7A48B"
                        BorderThickness="1"
                        Margin="0,0,0,20"
                        Height="350">
                    <StackPanel>
                        <TextBlock Text="📚 Истории и воспоминания" 
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#5C4E3D"
                                   Margin="0,0,0,15"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="240">
                            <ListView x:Name="lvStories" 
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F5F0E6"
                                                CornerRadius="8"
                                                Padding="15"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="📖" 
                                                           FontSize="20"
                                                           Foreground="#8FAA7A"
                                                           Margin="0,0,10,0"/>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontWeight="Bold"
                                                               Foreground="#5C4E3D"/>
                                                    <TextBlock Text="{Binding EventDateString}" 
                                                               Foreground="#8B7E6B"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding ShortContent}" 
                                                               Foreground="#6B5E4A"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="40"/>
                                                </StackPanel>

                                                <Button Grid.Column="2" 
                                                        Content="Читать"
                                                        Background="#8FAA7A"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Padding="10,5"
                                                        Tag="{Binding Id}"
                                                        Click="ReadStory_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>

                        <Button x:Name="btnAddStoryBottom" 
                                Content="➕ Добавить историю" 
                                Width="150" Height="35"
                                Background="Transparent"
                                BorderBrush="#B7A48B"
                                Foreground="#5C4E3D"
                                BorderThickness="1"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Click="AddStoryButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Медиафайлы с ScrollViewer -->
                <Border Background="#FDF8F0"
                        CornerRadius="15"
                        Padding="20"
                        BorderBrush="#B7A48B"
                        BorderThickness="1"
                        Height="450">
                    <StackPanel>
                        <TextBlock Text="🖼️ Медиафайлы" 
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#5C4E3D"
                                   Margin="0,0,0,15"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="320">
                            <TabControl BorderThickness="0" Background="Transparent">
                                <TabItem Header="Фотографии" Background="#F5F0E6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                                        <ItemsControl x:Name="icPhotos" Margin="5">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="120" Height="120"
                                                            Margin="5"
                                                            BorderBrush="#B7A48B"
                                                            BorderThickness="1"
                                                            CornerRadius="5">
                                                        <Image Source="{Binding ThumbPath}" 
                                                               Stretch="UniformToFill"
                                                               Tag="{Binding Id}"
                                                               MouseLeftButtonDown="Photo_Click"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Видео" Background="#F5F0E6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                                        <ItemsControl x:Name="icVideos" Margin="5">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="120" Height="120"
                                                            Margin="5"
                                                            BorderBrush="#B7A48B"
                                                            BorderThickness="1"
                                                            CornerRadius="5"
                                                            Background="#F5F0E6">
                                                        <StackPanel>
                                                            <TextBlock Text="🎥" 
                                                                       FontSize="40"
                                                                       Foreground="#8FAA7A"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock Text="{Binding FileName}" 
                                                                       Foreground="#6B5E4A"
                                                                       FontSize="10"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Аудио" Background="#F5F0E6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                                        <ItemsControl x:Name="icAudios" Margin="5">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="5"
                                                            Padding="10"
                                                            BorderBrush="#B7A48B"
                                                            BorderThickness="1"
                                                            CornerRadius="5">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🎵" 
                                                                       FontSize="20"
                                                                       Foreground="#8FAA7A"
                                                                       Margin="0,0,10,0"/>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding FileName}" 
                                                                           Foreground="#5C4E3D"
                                                                           FontWeight="SemiBold"/>
                                                                <Button Content="▶ Слушать" 
                                                                        Background="Transparent"
                                                                        BorderBrush="#B7A48B"
                                                                        Foreground="#6B5E4A"
                                                                        BorderThickness="1"
                                                                        Padding="5"
                                                                        Tag="{Binding Id}"
                                                                        Click="PlayAudio_Click"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </ScrollViewer>

                        <Button x:Name="btnAddMedia" 
                                Content="➕ Добавить медиафайл" 
                                Width="150" Height="35"
                                Background="Transparent"
                                BorderBrush="#B7A48B"
                                Foreground="#5C4E3D"
                                BorderThickness="1"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Click="AddMediaButton_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>